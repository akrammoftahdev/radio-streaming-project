generator client {
  provider = "prisma-client-js"
}

datasource db {
  // LOCAL DEV ONLY: sqlite (DATABASE_URL = "file:./dev.db")
  // VPS / PRODUCTION: use schema.cloud.prisma (postgresql)
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String                @id @default(uuid())
  name         String?
  username     String                @unique
  passwordHash String                @map("password_hash")
  role         String                @default("PRESENTER")
  // SINGLE_STATION | MULTI_STATION | DIRECT_DJ
  // Controls studio gate and credential resolution:
  //   SINGLE_STATION: one station, uses program schedule + station DJ credentials.
  //   MULTI_STATION:  multiple stations, uses program schedule + station DJ credentials.
  //   DIRECT_DJ:      bypasses schedule entirely, connects directly via personal DirectDjRadio targets.
  presenterMode String                @default("SINGLE_STATION") @map("presenter_mode")
  email        String?               @unique
  phone        String?
  isActive     Boolean               @default(true) @map("is_active")
  canBroadcast Boolean               @default(true) @map("can_broadcast")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  accessLogs        AccessLog[]
  schedules         BroadcastSchedule[]
  liveSessions      LiveSession[]
  recordings        Recording[]
  profile           PresenterProfile?
  validity          PresenterValidity?
  sonicPanelCredentials SonicPanelCredential[]  // Step 4A-final: one-to-many (was one-to-one sonicPanel)
  presenterStations        PresenterStation[]
  programs                 Program[]
  stationManagerAssignments StationManagerAssignment[]
  directDjRadios           DirectDjRadio[]
  dspPresets               DspPreset[]           // custom DSP presets created by this presenter
  activeDspPresetId        String?               @map("active_dsp_preset_id")
}

model PresenterProfile {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  displayName String?  @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])
}

model PresenterValidity {
  id          String    @id @default(uuid())
  presenterId String    @unique @map("presenter_id")
  validFrom   DateTime? @map("valid_from")
  validTo     DateTime? @map("valid_to")
  timezone    String    @default("Africa/Cairo")
  isActive    Boolean   @default(true) @map("is_active")
  presenter   User      @relation(fields: [presenterId], references: [id])
}

model BroadcastSchedule {
  id                        String        @id @default(uuid())
  presenterId               String        @map("presenter_id")
  stationId                 String?       @map("station_id")
  startDatetime             DateTime      @map("start_datetime")
  endDatetime               DateTime      @map("end_datetime")
  timezone                  String        @default("Africa/Cairo")
  allowConnectMinutesBefore Int           @default(5) @map("allow_connect_minutes_before")
  isActive                  Boolean       @default(true) @map("is_active")
  presenter                 User          @relation(fields: [presenterId], references: [id])
  station                   Station?      @relation(fields: [stationId], references: [id], onDelete: SetNull)
  liveSessions              LiveSession[]
  recordings                Recording[]

  @@index([stationId])
}

model SonicPanelCredential {
  id                      String   @id @default(uuid())
  // Step 4A-final: @unique removed — replaced by compound @@unique([presenterId, stationId]) below.
  // Existing legacy rows (stationId IS NULL) remain valid as the presenter-wide fallback credential.
  presenterId             String   @map("presenter_id")
  // stationId = null  → legacy presenter-wide credential (backward-compatible fallback)
  // stationId = <id>  → per-presenter-per-station credential (production path)
  stationId               String?  @map("station_id")
  host                    String
  port                    Int
  djUsername              String   @map("dj_username")
  djPasswordEncrypted     String   @map("dj_password_encrypted")
  streamPasswordEncrypted String?  @map("stream_password_encrypted")
  mount                   String?
  sid                     String?
  bitrate                 Int      @default(64)
  isActive                Boolean  @default(true) @map("is_active")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")
  presenter               User     @relation(fields: [presenterId], references: [id])
  station                 Station? @relation(fields: [stationId], references: [id], onDelete: SetNull)

  @@unique([presenterId, stationId])
  @@index([stationId])
}

// MediaCategory.type values:
//   BACKGROUND — music played under speech
//   SONG       — full songs (auto-fade when mic opens)
//   BREAK      — station break / jingle
//   AD         — advertisement / promo
//   SFX        — sound effects (riser, boom, whoosh, impact, applause)
//
// MediaCategory.ownerType values:
//   ADMIN      — station-wide content managed by admin
//   PRESENTER  — personal content owned by a specific presenter (future)
//
// For MVP:
//   All existing categories are ADMIN-owned.
//   PRESENTER-owned categories are reserved for the local device file picker (Group 4.4+).
model MediaCategory {
  id           String       @id @default(uuid())
  name         String
  // BACKGROUND | SONG | BREAK | AD
  type         String
  // ADMIN | PRESENTER
  ownerType    String       @default("ADMIN") @map("owner_type")
  // For PRESENTER-owned categories, link to the owning user.
  // NULL for ADMIN-owned categories.
  ownerId      String?      @map("owner_id")
  // Station scoping:
  //   NULL  = global (visible to all stations)
  //   <id>  = scoped to a specific station only
  stationId    String?      @map("station_id")
  displayOrder Int          @default(0) @map("display_order")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  tracks       MediaTrack[]
  station      Station?     @relation(fields: [stationId], references: [id], onDelete: SetNull)

  @@index([stationId])
}

model MediaTrack {
  id           String        @id @default(uuid())
  categoryId   String        @map("category_id")
  type         String
  title        String
  artist       String?
  fileUrl      String        @map("file_url")
  duration     Int?
  mimeType     String?       @map("mime_type")
  size         Int?
  displayOrder Int           @default(0) @map("display_order")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  category     MediaCategory @relation(fields: [categoryId], references: [id])
}

model LiveSession {
  id                       String             @id @default(uuid())
  presenterId              String             @map("presenter_id")
  scheduleId               String?            @map("schedule_id")
  status                   String
  connectedAt              DateTime           @default(now()) @map("connected_at")
  disconnectedAt           DateTime?          @map("disconnected_at")
  disconnectReason         String?            @map("disconnect_reason")
  networkQuality           String?            @map("network_quality")
  sonicConnectionStatus    String?            @map("sonic_connection_status")
  currentMicState          Boolean            @default(false) @map("current_mic_state")
  currentBackgroundTrackId String?            @map("current_background_track_id")
  currentSongTrackId       String?            @map("current_song_track_id")
  queuedSongTrackId        String?            @map("queued_song_track_id")
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")
  schedule                 BroadcastSchedule? @relation(fields: [scheduleId], references: [id])
  presenter                User               @relation(fields: [presenterId], references: [id])
  recordings               Recording[]
}

model AccessLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  attemptedAt    DateTime @default(now()) @map("attempted_at")
  result         String
  reason         String?
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  deviceType     String?  @map("device_type")
  networkQuality String?  @map("network_quality")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id])
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  // Legacy field — kept for backward compatibility with existing rows.
  // New code should write actorId + actorRole instead.
  adminId    String?  @map("admin_id")
  // ── Actor fields (added 2026-05-11) ─────────────────────────────────────
  // actorId   = userId of the ADMIN or STATION_MANAGER who performed the action.
  // actorRole = "ADMIN" | "STATION_MANAGER"
  // stationId = affected station (null for global ADMIN actions)
  actorId    String?  @map("actor_id")
  actorRole  String?  @map("actor_role")
  stationId  String?  @map("station_id")
  // ── Action fields ────────────────────────────────────────────────────────
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   String?
  createdAt  DateTime @default(now()) @map("created_at")
}

model AudioTransitionSettings {
  id                            String   @id @default(uuid())
  fadeDurationMs                Int      @default(1500) @map("fade_duration_ms")
  songFadeDownOnMicOn           Boolean  @default(true) @map("song_fade_down_on_mic_on")
  backgroundFadeDownOnSongStart Boolean  @default(true) @map("background_fade_down_on_song_start")
  backgroundLoopDefault         Boolean  @default(true) @map("background_loop_default")
  shuffleSameCategory           Boolean  @default(true) @map("shuffle_same_category")
  avoidRecentRepeatCount        Int      @default(10) @map("avoid_recent_repeat_count")
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")
}

// ── Recording ────────────────────────────────────────────────────────────────
// Stores metadata for every local WebM recording produced by backend-audio.
//
// Storage strategy (MVP):
//   Files are saved on the same server/filesystem as backend-audio.
//   localPath stores the relative filename only (e.g. "session-20260428-....webm").
//   The serving layer resolves the absolute path from the RECORDINGS_BASE_DIR env var
//   so the archive does not break if the deployment directory changes.
//
// Cloud storage:
//   cloudUrl is reserved for a future optional phase.
//   It is always null in the current MVP and must never be required by any query.

model Recording {
  // Primary key
  id              String    @id @default(cuid())

  // Foreign keys (all nullable where the relationship may be unavailable at write time)
  presenterId     String?   @map("presenter_id")  // nullable for archive safety — snapshot fields hold the name
  liveSessionId   String?   @map("live_session_id")
  scheduleId      String?   @map("schedule_id")

  // Show context
  showDate        DateTime? @map("show_date")

  // Timing
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationSeconds Int?      @map("duration_seconds")

  // File location
  // Relative filename only — e.g. "session-20260428-130932-5f3ba1d8.webm"
  // Do NOT store absolute paths here.
  localPath       String    @map("local_path")

  // Audio properties
  format          String    @default("audio/webm") @map("format")
  bitrate         Int?
  bytesReceived   Int?      @map("bytes_received")

  // Cloud storage (deferred — always null in MVP)
  cloudUrl        String?   @map("cloud_url")

  // Audit
  createdAt       DateTime  @default(now()) @map("created_at")

  // Context — populated at recording creation; all nullable so existing rows are unaffected.
  // stationId:      which internal station was broadcasting (null for Direct DJ).
  // programId:      which program this recording belongs to (null for Direct DJ / legacy).
  // sourceType:     SCHEDULED_PROGRAM | DIRECT_DJ (null for legacy recordings pre-migration).
  // directDjRadioId: which DirectDjRadio target was used (null unless sourceType=DIRECT_DJ).
  stationId        String?  @map("station_id")
  programId        String?  @map("program_id")
  sourceType       String?  @map("source_type")
  directDjRadioId  String?  @map("direct_dj_radio_id")

  // Historical snapshot — populated at recording creation and before entity deletion.
  // If the presenter/station/program is later deleted these fields preserve the display name.
  presenterNameSnapshot      String?  @map("presenter_name_snapshot")
  presenterUsernameSnapshot  String?  @map("presenter_username_snapshot")
  stationNameSnapshot        String?  @map("station_name_snapshot")
  programTitleSnapshot       String?  @map("program_title_snapshot")
  presenterDeleted           Boolean  @default(false) @map("presenter_deleted")
  stationDeleted             Boolean  @default(false) @map("station_deleted")

  // Relations
  presenter       User?              @relation(fields: [presenterId], references: [id], onDelete: SetNull)
  liveSession     LiveSession?       @relation(fields: [liveSessionId], references: [id])
  schedule        BroadcastSchedule? @relation(fields: [scheduleId], references: [id])
  station         Station?           @relation(fields: [stationId], references: [id], onDelete: SetNull)
  program         Program?           @relation(fields: [programId], references: [id], onDelete: SetNull)
  directDjRadio   DirectDjRadio?     @relation(fields: [directDjRadioId], references: [id], onDelete: SetNull)

  @@map("recordings")
}

// ── Station ──────────────────────────────────────────────────────────────────
// Represents a single radio station (stream endpoint).
// Presenters are linked to one or more stations via PresenterStation.
// Schedule conflict checks will be scoped per station.
// SonicPanel credentials will become per (presenter + station) in a later phase.

model Station {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  streamHost  String?  @map("stream_host")
  streamPort  Int?     @map("stream_port")
  publicUrl   String?  @map("public_url")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  presenterStations     PresenterStation[]
  schedules             BroadcastSchedule[]
  programs              Program[]
  exceptions            ProgramScheduleException[]
  sonicPanelCredentials SonicPanelCredential[]       // per-presenter credentials
  defaultCredential     StationDefaultCredential?    // station-level fallback DJ credential
  stationManagers       StationManagerAssignment[]   // managers assigned to this station
  recordings            Recording[]                  // recordings made on this station
  mediaCategories       MediaCategory[]              // media categories scoped to this station
}

// ── StationDefaultCredential ──────────────────────────────────────────────────
// Stores a station-level fallback DJ/SonicPanel credential.
// Credential resolution priority in the validate route:
//   1. SonicPanelCredential WHERE presenterId = ? AND stationId = ?   (per-presenter+station)
//   2. SonicPanelCredential WHERE presenterId = ? AND stationId NULL   (legacy presenter-wide)
//   3. StationDefaultCredential WHERE stationId = ?                   (THIS MODEL — station fallback)
//   4. null → backend-audio falls back to .env dev credentials
//
// encryptedPassword is stored AES-256-CBC via the existing encrypt() helper.
// NEVER log or expose the decrypted value.

model StationDefaultCredential {
  id                String   @id @default(uuid())
  stationId         String   @unique @map("station_id")
  host              String
  port              Int
  djUsername        String   @map("dj_username")
  encryptedPassword String   @map("encrypted_password")
  mount             String?
  sid               String?
  bitrate           Int      @default(128)
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  station           Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
}

// ── PresenterStation ─────────────────────────────────────────────────────────
// Join table: links a presenter (User) to a Station.
// A presenter may be assigned to multiple stations.
// A station may have multiple presenters.

model PresenterStation {
  id          String   @id @default(uuid())
  presenterId String   @map("presenter_id")
  stationId   String   @map("station_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  presenter User    @relation(fields: [presenterId], references: [id], onDelete: Cascade)
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([presenterId, stationId])
  @@index([presenterId])
  @@index([stationId])
}

// ── RecurrenceType values (stored as String for flexibility) ─────────────────
// Valid: DAILY | WEEKLY | SELECTED_DAYS | ONE_TIME

// ── ExceptionType values (stored as String for flexibility) ──────────────────
// Valid: EXTRA_EPISODE | SPECIAL_EVENT | CANCELLED | RESCHEDULED

// ── Program ───────────────────────────────────────────────────────────────────
// A named radio show owned by a presenter, scoped to a station.
// One presenter may run multiple programs across multiple stations.
model Program {
  id          String   @id @default(uuid())
  presenterId String   @map("presenter_id")
  stationId   String   @map("station_id")
  title       String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  // Validity window — both nullable (null = no restriction).
  // validFrom:  program won't appear in schedule before this date.
  // validUntil: program stops appearing after this date.
  validFrom   DateTime? @map("valid_from")
  validUntil  DateTime? @map("valid_until")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  presenter User    @relation(fields: [presenterId], references: [id])
  station   Station @relation(fields: [stationId],   references: [id])

  scheduleRules ProgramScheduleRule[]
  exceptions    ProgramScheduleException[]
  recordings    Recording[]

  @@index([presenterId])
  @@index([stationId])
}

// ── ProgramScheduleRule ───────────────────────────────────────────────────────
// One recurrence rule per program (a program may have multiple rules).
// Rules contain one or more ProgramScheduleSlot rows for day/time pairs.
model ProgramScheduleRule {
  id                        String         @id @default(uuid())
  programId                 String         @map("program_id")
  recurrenceType            String         @map("recurrence_type")  // DAILY | WEEKLY | SELECTED_DAYS | ONE_TIME
  timezone                  String         @default("Africa/Cairo")
  allowConnectMinutesBefore Int            @default(5) @map("allow_connect_minutes_before")
  isActive                  Boolean        @default(true) @map("is_active")
  createdAt                 DateTime       @default(now()) @map("created_at")

  program Program               @relation(fields: [programId], references: [id], onDelete: Cascade)
  slots   ProgramScheduleSlot[]

  @@index([programId])
}

// ── ProgramScheduleSlot ───────────────────────────────────────────────────────
// One row = one day-of-week + start/end time pair within a rule.
// DAILY        : one row, dayOfWeek = null
// WEEKLY       : one row, dayOfWeek = 0-6
// SELECTED_DAYS: one row per selected day
// ONE_TIME     : one row, slotDate = the specific date
model ProgramScheduleSlot {
  id        String    @id @default(uuid())
  ruleId    String    @map("rule_id")
  dayOfWeek Int?      @map("day_of_week")  // 0=Sun … 6=Sat; null for DAILY/ONE_TIME
  slotDate  DateTime? @map("slot_date")    // set only for ONE_TIME rules
  startTime String    @map("start_time")   // "HH:MM" 24-hour
  endTime   String    @map("end_time")     // "HH:MM" 24-hour
  isActive  Boolean   @default(true) @map("is_active")

  rule ProgramScheduleRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

// ── ProgramScheduleException ──────────────────────────────────────────────────
// Overrides a single occurrence of a recurring rule, or adds a special episode.
model ProgramScheduleException {
  id            String        @id @default(uuid())
  programId     String        @map("program_id")
  stationId     String        @map("station_id")
  exceptionDate DateTime      @map("exception_date")
  type          String        // EXTRA_EPISODE | SPECIAL_EVENT | CANCELLED | RESCHEDULED
  title         String?
  startTime     String?       @map("start_time")   // null = full cancellation
  endTime       String?       @map("end_time")
  reason        String?
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id])

  @@index([programId])
  @@index([stationId])
  @@index([exceptionDate])
}

// ── StationManagerAssignment ──────────────────────────────────────────────────
// Links a STATION_MANAGER user to one or more stations.
// A Station Manager CAN be assigned to multiple stations (multi-station support).
// Multiple managers can be assigned to the same station.
// @@unique([managerId, stationId]) prevents duplicate pairs but does NOT limit
// a manager to a single station — they may have one row per station.
// Admin creates/removes assignments — managers cannot self-assign.

model StationManagerAssignment {
  id        String   @id @default(uuid())
  managerId String   @map("manager_id")
  stationId String   @map("station_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")    // adminId who made this assignment

  manager User    @relation(fields: [managerId], references: [id], onDelete: Cascade)
  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@unique([managerId, stationId])
  @@index([managerId])
  @@index([stationId])
}

// ── DirectDjRadio ────────────────────────────────────────────────────
// Personal radio broadcast targets for DIRECT_DJ presenters.
// Each row is one external SHOUTcast / IceCast endpoint the presenter
// can connect to directly from Studio, bypassing the Program Schedule.
//
// Credential resolution for DIRECT_DJ:
//   1. DirectDjRadio WHERE presenterId=X AND id=selectedRadioId AND isActive=true
//   2. fail — no fallback to Station, SonicPanelCredential, or StationDefaultCredential
//
// encryptedPassword is stored AES-256-CBC via the existing encrypt() helper.
// NEVER log or expose the decrypted value.

model DirectDjRadio {
  id                String   @id @default(uuid())
  presenterId       String   @map("presenter_id")
  radioName         String   @map("radio_name")           // e.g. "مصر راديو الحدث"
  host              String
  port              Int
  djUsername        String   @map("dj_username")
  encryptedPassword String   @map("encrypted_password")   // AES-256-CBC via encrypt()
  mount             String?                               // e.g. "/stream"
  sid               String?                               // SHOUTcast SID
  bitrate           Int      @default(128)
  isActive          Boolean  @default(true) @map("is_active")
  displayOrder      Int      @default(0)   @map("display_order") // UI card ordering
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt     @map("updated_at")

  presenter  User        @relation(fields: [presenterId], references: [id], onDelete: Cascade)
  recordings Recording[]                                 // recordings made on this target

  @@index([presenterId])
}

// ── SystemSettings ────────────────────────────────────────────────────────────
//
// Singleton branding / theme config table.
// Always exactly ONE row: id = "global".
// Read by server layout to inject CSS tokens + display system name.
// Write only through /admin/settings pages (full admin only).
// Safe defaults match current hardcoded values so the system looks identical
// until an admin changes them.
//
// upsert pattern:  prisma.systemSettings.upsert({
//   where:  { id: "global" },
//   create: { id: "global" },
//   update: {},          // never overwrite on seed
// })
//
// Theme colors are hex strings (e.g. "#6366f1") that map to CSS --eg-* tokens.
// null = use CSS default from globals.css (safe fallback).
//
model SystemSettings {
  id              String   @id @default("global")

  // ── Branding ──────────────────────────────────────────────────────────────
  systemName      String   @default("EGONAIR")           @map("system_name")
  systemSubtitle  String?                                 @map("system_subtitle")
  logoUrl         String?                                 @map("logo_url")         // legacy / generic fallback
  logoDarkUrl     String?                                 @map("logo_dark_url")    // logo for dark mode
  logoLightUrl    String?                                 @map("logo_light_url")   // logo for light mode
  loginLogoDarkUrl  String?                               @map("login_logo_dark_url")  // login page dark logo
  loginLogoLightUrl String?                               @map("login_logo_light_url") // login page light logo
  mobileAppIconUrl  String?                               @map("mobile_app_icon_url")  // PWA / mobile app icon
  splashScreenUrl   String?                               @map("splash_screen_url")    // splash screen image
  faviconUrl      String?                                 @map("favicon_url")

  // ── Support contacts ──────────────────────────────────────────────────────
  supportPhone    String?                                 @map("support_phone")
  supportWhatsapp String?                                 @map("support_whatsapp")
  supportEmail    String?                                 @map("support_email")

  // ── Theme ─────────────────────────────────────────────────────────────────
  defaultTheme    String   @default("dark")               @map("default_theme")
  // Dark theme overrides (null = use globals.css defaults)
  darkPrimary     String?                                 @map("dark_primary")
  darkAccent      String?                                 @map("dark_accent")
  darkBackground  String?                                 @map("dark_background")
  darkSurface     String?                                 @map("dark_surface")
  darkText        String?                                 @map("dark_text")
  // Light theme overrides (null = light theme not customised yet)
  lightPrimary    String?                                 @map("light_primary")
  lightAccent     String?                                 @map("light_accent")
  lightBackground String?                                 @map("light_background")
  lightSurface    String?                                 @map("light_surface")
  lightText       String?                                 @map("light_text")

  // ── Meta ──────────────────────────────────────────────────────────────────
  updatedBy       String?                                 @map("updated_by")
  createdAt       DateTime @default(now())                @map("created_at")
  updatedAt       DateTime @updatedAt                     @map("updated_at")
}

// ── DSP Mic Presets ─────────────────────────────────────────────────────────
// Stores per-presenter mic processing presets (EQ, compressor, gate, etc.).
// System presets have isSystem=true and presenterId=null.
model DspPreset {
  id          String   @id @default(uuid())
  name        String
  // SYSTEM presets are read-only defaults; USER presets are per-presenter.
  isSystem    Boolean  @default(false) @map("is_system")
  presenterId String?  @map("presenter_id")
  // JSON blob storing all filter parameters
  // Schema: { hpFreq, lpFreq, eqLow, eqMid, eqHigh, eqLowFreq, eqMidFreq, eqHighFreq,
  //           compThreshold, compRatio, compAttack, compRelease, compKnee,
  //           limiterThreshold, gateThreshold, gateAttack, gateRelease,
  //           deEsserFreq, deEsserQ, deEsserReduction,
  //           reverbWet, reverbDecay, delayTime, delayFeedback, delayWet,
  //           warmthAmount, stereoWidth }
  params      String   @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  presenter   User?    @relation(fields: [presenterId], references: [id], onDelete: Cascade)

  @@index([presenterId])
}
