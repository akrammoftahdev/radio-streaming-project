# backend-audio/.env
# ─────────────────────────────────────────────────────────────────────────────
# Feature flag — controls whether the live FFmpeg→SHOUTcast pipeline fires.
# Keep this FALSE in development unless you intend to broadcast live.
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_SHOUTCAST_LIVE=true

# SHOUTcast / SonicPanel source connection credentials
# Used only when ENABLE_SHOUTCAST_LIVE=true.
# In production these values should come from the encrypted admin credentials.
SHOUTCAST_HOST=stream.example.com
SHOUTCAST_PORT=8000
SHOUTCAST_PASSWORD=your-dj-password-here
SHOUTCAST_DJ_USERNAME=your-dj-username-here
SHOUTCAST_SOURCE_PATH=/
SHOUTCAST_BITRATE=64

# Legacy / unused — kept for reference
# SHOUTCAST_SID=1
# SHOUTCAST_MODE=v1
