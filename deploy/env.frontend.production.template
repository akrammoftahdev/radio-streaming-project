# ============================================================
# EGONAIR — Frontend Production Environment Variables
# File: ~/apps/egonair-stream/frontend/.env
#
# ⚠️  NEVER commit this file to git.
# ⚠️  Generate real secrets before go-live.
# ============================================================

# ── Database ────────────────────────────────────────────────
# Use an absolute path on the server.
# Replace <YOUR_CPANEL_USER> with your actual cPanel username.
DATABASE_URL="file:/home/<YOUR_CPANEL_USER>/apps/egonair-stream/frontend/prisma/prod.db"

# ── NextAuth ─────────────────────────────────────────────────
# NEXTAUTH_URL must match the public URL of the Next.js app.
# Since the app is served at egonair.com/stream, use:
NEXTAUTH_URL="https://egonair.com/stream"

# Generate a strong secret: openssl rand -hex 32
AUTH_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# ── Encryption (SonicPanel credential AES key) ───────────────
# ⚠️  If you change this, all existing encrypted credentials become invalid.
# ⚠️  Must be exactly 32 hex characters (16 bytes / 128 bits).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_HEX_KEY"

# ── Audio session token ───────────────────────────────────────
# Short-lived JWT secret for studio mic connection.
# Generate: openssl rand -hex 32
AUDIO_TOKEN_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# ── Recordings directory ──────────────────────────────────────
# Must be an ABSOLUTE path on the server.
# Must NOT be inside public_html.
RECORDINGS_BASE_DIR="/home/<YOUR_CPANEL_USER>/recordings"

# ── WebSocket URL (browser-facing) ───────────────────────────
# This is the WSS URL the browser Studio UI connects to.
# Served via reverse proxy: egonair.com/stream-ws → 127.0.0.1:4001
NEXT_PUBLIC_WS_URL="wss://egonair.com/stream-ws"

# ── Node environment ─────────────────────────────────────────
NODE_ENV="production"
