# ============================================================
# EGONAIR — Backend-Audio Production Environment Variables
# File: ~/apps/egonair-stream/backend-audio/.env
#
# ⚠️  NEVER commit this file to git.
# ============================================================

# ── Feature flag ─────────────────────────────────────────────
# Set to true to enable the live FFmpeg → SHOUTcast pipeline.
ENABLE_SHOUTCAST_LIVE=true

# ── Internal communication ────────────────────────────────────
# These stay as localhost — backend-audio and Next.js are on the same server.
# Do NOT change these unless running on separate machines.
NEXT_VALIDATE_URL=http://localhost:3000/api/internal/audio-token/validate
NEXT_SESSION_BASE_URL=http://localhost:3000/api/internal/audio-session

# ── Dev/smoke-test SHOUTcast fallback ────────────────────────
# Only used when a presenter has NO SonicPanelCredential row in the DB.
# In production with all presenters configured, these are never used.
# Leave blank to force rejection (safe for production):
SHOUTCAST_HOST=
SHOUTCAST_PORT=4896
SHOUTCAST_PASSWORD=
SHOUTCAST_DJ_USERNAME=source
SHOUTCAST_SOURCE_PATH=/
SHOUTCAST_BITRATE=64

# ── Node environment ─────────────────────────────────────────
NODE_ENV=production
