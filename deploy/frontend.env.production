# ============================================================
# EGONAIR — Frontend Production Environment
# Location on VPS: /home/egyona/apps/egonair-stream/current/frontend/.env
#
# ⚠️  NEVER commit this file to git.
# ⚠️  Replace every TODO value before starting the app.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# SQLite absolute path — must be outside the release folder
# so it survives deploys (lives in shared/).
DATABASE_URL="file:/home/egyona/apps/egonair-stream/shared/prod.db"

# ── NextAuth v5 ───────────────────────────────────────────────
# AUTH_SECRET is the canonical name for next-auth v5 beta.
# NEXTAUTH_URL is also read by the library for redirect base path.
#
# Generate AUTH_SECRET:  openssl rand -hex 32
AUTH_SECRET="TODO_REPLACE_openssl_rand_-hex_32"

# Public URL of the Next.js app.
# Because basePath="/stream", this must include /stream.
NEXTAUTH_URL="https://egonair.com/stream"

# next-auth v5 requires explicit host trust in production
AUTH_TRUST_HOST=true
# AUTH_URL — for next-auth v5 beta.31 + Next.js basePath:
# Must be the domain ONLY (no path). Next.js basePath handles /stream prefix.
# Setting this to https://egonair.com/stream causes "Cannot parse action" errors.
AUTH_URL=https://egonair.com

# ── Encryption (SonicPanel DJ credentials at rest) ───────────
# ⚠️  Must be exactly 32 hex characters (16 bytes).
# ⚠️  Changing this invalidates ALL encrypted DJ credentials.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="TODO_REPLACE_openssl_rand_-hex_32"

# ── Audio session token (short-lived JWT for WebSocket auth) ──
# Generate: openssl rand -hex 32
AUDIO_TOKEN_SECRET="TODO_REPLACE_openssl_rand_-hex_32"

# ── Recordings directory ──────────────────────────────────────
# Must be an ABSOLUTE path on the server.
# Shared folder survives deployments.
RECORDINGS_BASE_DIR="/home/egyona/apps/egonair-stream/shared/recordings"

# ── WebSocket URL (sent to browser, used in Studio UI) ────────
# The browser connects to this URL for the audio WebSocket.
# Served through the reverse proxy: egonair.com/stream-ws → 127.0.0.1:4001
# Set to wss:// (secure) — required when site is HTTPS.
#
# NOTE: This is a NEXT_PUBLIC_ variable — it is embedded in the
# browser bundle at build time. Set it correctly BEFORE running
# npm run build.
NEXT_PUBLIC_WS_URL="wss://egonair.com/stream-ws"

# ── Node / app environment ────────────────────────────────────
NODE_ENV="production"

# ── basePath control ─────────────────────────────────────────
# Leave unset for production (basePath="/stream" will be used).
# Set to "1" ONLY for local dev if basePath causes issues:
# SKIP_BASEPATH=1
